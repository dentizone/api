# .github/workflows/code-cleanup.yml

name: Code Cleanup

on:
  pull_request:
    branches:
      - dev

jobs:
  format-and-lint:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          # Checkout the head of the pull request branch
          ref: ${{ github.head_ref }}

      - name: Setup .NET
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x' # It's a good practice to specify the .NET version

      - name: Install dotnet-format
        run: dotnet tool install -g dotnet-format

      - name: Run dotnet format to fix unused usings
        run: dotnet format

      - name: Commit changes
        uses: stefanzweifel/git-auto-commit-action@v5
        with:
          commit_message: "chore: remove unused imports"
          branch: ${{ github.head_ref }}
