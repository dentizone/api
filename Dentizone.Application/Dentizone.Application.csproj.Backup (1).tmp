<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="AutoMapper\NewFolder\**" />
    <EmbeddedResource Remove="AutoMapper\NewFolder\**" />
    <None Remove="AutoMapper\NewFolder\**" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="DTOs\Cart\" />
    <Folder Include="Services\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AutoMapper" Version="14.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Dentizone.Infrastructure\Dentizone.Infrastructure.csproj" />
  </ItemGroup>

</Project>
